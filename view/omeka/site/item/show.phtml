<?php
$translate = $this->plugin('translate');
$escape = $this->plugin('escapeHtml');

$this->headLink()->appendStylesheet($this->assetUrl('css/resource-page-blocks.css', 'Omeka'));
$this->htmlElement('body')->appendAttribute('class', 'item resource show');

$filterLocale = (bool) $this->siteSetting('filter_locale_values');
$lang = $this->lang();
$valueLang = $filterLocale ? [$lang, ''] : null;

// Regions
$mainBlockContent = $this->resourcePageBlocks($item);
$mainHasBlocks = $mainBlockContent->hasBlocks();
$leftSidebarBlockContent = $this->resourcePageBlocks($item, 'left');
$leftSidebarHasBlocks = $leftSidebarBlockContent->hasBlocks();
$rightSidebarBlockContent = $this->resourcePageBlocks($item, 'right');
$rightSidebarHasBlocks = $rightSidebarBlockContent->hasBlocks();

$extractValueTexts = function (array $values) {
    $texts = [];
    foreach ($values as $value) {
        if (is_object($value) && method_exists($value, 'value')) {
            $text = $value->value();
        } else {
            $text = (string) $value;
        }
        $text = trim((string) $text);
        if ($text !== '') {
            $texts[] = $text;
        }
    }
    return $texts;
};
$rightsVals = $extractValueTexts((array) $item->values('dcterms:rights'));
$accessVals = $extractValueTexts((array) $item->values('dcterms:accessRights'));
$allTexts = array_merge($rightsVals, $accessVals);
$rightsText = mb_strtolower(implode(' ', $allTexts));
$requiresPopup = ($rightsText !== '' && mb_strpos($rightsText, 'restricted') !== false);
$popupDebug = [
    'itemId' => (int) $item->id(),
    'rightsValues' => $rightsVals,
    'accessRightsValues' => $accessVals,
    'combinedText' => $rightsText,
    'requiresPopup' => $requiresPopup,
];
?>

<?php echo $this->ResourceTags($item); ?>
<?php echo $this->pageTitle($item->displayTitle(null, $valueLang), 1); ?>

<?php $this->trigger('view.show.before'); ?>

<?php if ($mainHasBlocks || $leftSidebarHasBlocks || $rightSidebarHasBlocks): ?>

    <?php
    $additionalContainerClasses = '';
    if ($mainHasBlocks && $leftSidebarHasBlocks && $rightSidebarHasBlocks) {
        $additionalContainerClasses = 'regions-container--all';
    } elseif ($mainHasBlocks && !$leftSidebarHasBlocks && !$rightSidebarHasBlocks) {
        $additionalContainerClasses = 'regions-container--main';
    }
    ?>

    <div class="regions-container <?php echo $additionalContainerClasses; ?>">
        <?php if ($leftSidebarHasBlocks && $blockContent = $leftSidebarBlockContent->getBlocks()): ?>
            <div class="sidebar-region sidebar-region--left">
                <div class="metadata">
                    <?php echo $blockContent; ?>
                </div>
            </div>
        <?php endif; ?>

        <?php if ($mainHasBlocks && $blockContent = $mainBlockContent->getBlocks()): ?>
            <div class="main-region">
                <div class="metadata">
                    <?php echo $blockContent; ?>
                </div>
            </div>
        <?php endif; ?>

        <?php if ($rightSidebarHasBlocks && $blockContent = $rightSidebarBlockContent->getBlocks()): ?>
            <div class="sidebar-region sidebar-region--right">
                <div class="metadata">
                    <?php echo $blockContent; ?>
                </div>
            </div>
        <?php endif; ?>
    </div>

<?php endif; ?>

<?php $this->trigger('view.show.after'); ?>

<?php if ($requiresPopup): ?>
    <div id="copyrightPopup" class="copyright-popup" hidden>
        <div class="copyright-popup__content" role="dialog" aria-modal="true" aria-labelledby="copyrightPopupTitle">
            <h3 id="copyrightPopupTitle"><?php echo $escape($translate('Copyright & Usage Agreement')); ?></h3>
            <p>
                <?php echo $escape($translate('This item is protected by copyright. By proceeding, you agree to use this content for academic and non-commercial purposes only.')); ?>
            </p>
            <div class="copyright-popup__buttons">
                <button type="button" id="agreeBtn"><?php echo $escape($translate('I Agree')); ?></button>
                <button type="button" id="cancelBtn" class="cancel"><?php echo $escape($translate('Cancel')); ?></button>
            </div>
        </div>
    </div>

    <input type="hidden" id="pendingDownloadUrl" value="">

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var popup = document.getElementById('copyrightPopup');
            var agreeButton = document.getElementById('agreeBtn');
            var cancelButton = document.getElementById('cancelBtn');
            var pendingDownloadUrl = document.getElementById('pendingDownloadUrl');
            var storageKey = 'omeka_copyright_agreed_item_<?php echo (int) $item->id(); ?>';
            var downloadSelector = 'a.media-download-link, a[href*="/files/original/"], .media-list a, .media-embeds a, .resource-list.media a';
            var debugInfo = <?php echo json_encode($popupDebug, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE); ?>;

            if (!popup || !agreeButton || !cancelButton || !pendingDownloadUrl) {
                console.warn('[Scopus terms debug] Required popup elements are missing.', debugInfo);
                return;
            }

            console.info('[Scopus terms debug] Restricted item detected.', debugInfo);
            console.info('[Scopus terms debug] Matching links found on page:', document.querySelectorAll(downloadSelector).length);

            function openPopup(url) {
                pendingDownloadUrl.value = url || '';
                popup.hidden = false;
                console.info('[Scopus terms debug] Opening popup.', {
                    pendingDownloadUrl: pendingDownloadUrl.value,
                    storageKey: storageKey
                });
            }

            function closePopup() {
                popup.hidden = true;
                pendingDownloadUrl.value = '';
            }

            if (sessionStorage.getItem(storageKey) !== 'true') {
                openPopup();
            } else {
                console.info('[Scopus terms debug] Popup already accepted for this item in sessionStorage.', {
                    storageKey: storageKey
                });
            }

            agreeButton.addEventListener('click', function () {
                var targetUrl = pendingDownloadUrl.value;

                sessionStorage.setItem(storageKey, 'true');
                closePopup();
                console.info('[Scopus terms debug] User agreed to terms.', {
                    storageKey: storageKey,
                    targetUrl: targetUrl
                });

                if (targetUrl) {
                    window.location.href = targetUrl;
                }
            });

            cancelButton.addEventListener('click', function () {
                console.info('[Scopus terms debug] User canceled terms popup.');
                if (window.history.length > 1) {
                    window.history.back();
                    return;
                }

                window.location.href = <?php echo json_encode($site->url()); ?>;
            });

            document.addEventListener('click', function (event) {
                var link = event.target.closest(downloadSelector);
                if (!link || !link.href) {
                    return;
                }

                console.info('[Scopus terms debug] Matching link clicked.', {
                    href: link.href,
                    text: (link.textContent || '').trim(),
                    className: link.className || ''
                });

                if (sessionStorage.getItem(storageKey) === 'true') {
                    console.info('[Scopus terms debug] Allowing click because terms were already accepted.', {
                        storageKey: storageKey
                    });
                    return;
                }

                if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || link.target === '_blank') {
                    console.info('[Scopus terms debug] Not intercepting click due to modifier key or _blank target.', {
                        metaKey: event.metaKey,
                        ctrlKey: event.ctrlKey,
                        shiftKey: event.shiftKey,
                        altKey: event.altKey,
                        target: link.target || ''
                    });
                    return;
                }

                event.preventDefault();
                openPopup(link.href);
            });
        });
    </script>

    <style>
        .copyright-popup {
            position: fixed;
            z-index: 9999;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: rgba(0, 0, 0, 0.6);
        }

        .copyright-popup[hidden] {
            display: none;
        }

        .copyright-popup__content {
            max-width: 520px;
            padding: 2rem;
            border-radius: 8px;
            background: #fff;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
        }

        .copyright-popup__buttons {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-top: 1.5rem;
        }

        .copyright-popup__buttons button {
            padding: 0.6rem 1.2rem;
            border: 0;
            border-radius: 4px;
            cursor: pointer;
            font-size: 1rem;
        }

        #agreeBtn {
            background-color: #007bff;
            color: #fff;
        }

        #agreeBtn:hover {
            background-color: #0056b3;
        }

        #cancelBtn {
            background-color: #ccc;
            color: #000;
        }

        #cancelBtn:hover {
            background-color: #999;
        }
    </style>
<?php endif; ?>

<?php if (!$requiresPopup): ?>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            console.info('[Scopus terms debug] Popup not enabled for this item.', <?php echo json_encode($popupDebug, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE); ?>);
        });
    </script>
<?php endif; ?>
