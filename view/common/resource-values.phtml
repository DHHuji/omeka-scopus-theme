<?php
$translate = $this->plugin('translate');
$escape = $this->plugin('escapeHtml');
$decoration = $this->themeSetting('image_decoration');

if ($this->status()->isSiteRequest()) {
    $labelInfo = $this->siteSetting('property_label_information');
    $showLocale = (bool) $this->siteSetting('show_locale_label', true);
    $filterLocale = $this->siteSetting('filter_locale_values');
    $lang = $this->lang();
    $showValueAnnotations = (bool) $this->siteSetting('show_value_annotations', false);
} else {
    $labelInfo = $this->setting('property_label_information');
    $showLocale = true;
    $filterLocale = false;
    $lang = null;
    $showValueAnnotations = true;
}
$filterLocaleCallback = function ($value) use ($lang) {
    $valueLang = $value->lang();
    return $valueLang == '' || strcasecmp($valueLang, $lang) === 0;
};

$collapsibleMap = [];
$normalizeCollapsibleValues = function ($raw) {
    if (is_array($raw)) {
        return array_filter(array_map('trim', $raw), 'strlen');
    }
    if (!is_string($raw) || $raw === '') {
        return [];
    }
    return array_filter(array_map('trim', preg_split("/\\r\\n|\\r|\\n/", $raw)), 'strlen');
};
$collapsedRaw = $this->themeSetting('collapsible_properties_collapsed');
foreach ($normalizeCollapsibleValues($collapsedRaw) as $value) {
    $collapsibleMap[(string) $value] = false;
}
$expandedRaw = $this->themeSetting('collapsible_properties_expanded');
foreach ($normalizeCollapsibleValues($expandedRaw) as $value) {
    $collapsibleMap[(string) $value] = true;
}

$normalizePropertySelectValues = function ($raw) {
    if (is_array($raw)) {
        return array_values(array_unique(array_filter(array_map('strval', $raw), 'strlen')));
    }
    if (!is_string($raw) || $raw === '') {
        return [];
    }
    return array_values(array_unique(array_filter(array_map('trim', preg_split("/\\r\\n|\\r|\\n/", $raw)), 'strlen')));
};

$tabsMode = (string) $this->themeSetting('resource_page_values_mode', 'default');
$useTemplateGroups = (bool) $this->themeSetting('resource_page_use_template_groups', false);
$templateGroupDebug = [
    'tabs_mode' => $tabsMode,
    'use_template_groups' => $useTemplateGroups,
    'resource_is_set' => isset($resource),
    'resource_class' => isset($resource) && is_object($resource) ? get_class($resource) : null,
    'template_found' => false,
    'template_class' => null,
    'template_label' => null,
    'template_jsonld_group_keys_present' => [],
    'template_group_labels' => [],
    'template_property_group_labels' => [],
    'configured_tabs_source' => 'manual',
    'configured_tab_labels' => [],
];

$extractPropertyIdentifiers = function ($propertyData) {
    $identifiers = [];
    if (is_scalar($propertyData)) {
        $value = trim((string) $propertyData);
        if ($value !== '') {
            $identifiers[$value] = true;
        }
        return $identifiers;
    }
    if (!is_array($propertyData)) {
        return $identifiers;
    }
    foreach (['o:id', 'id', 'o:term', 'term', '@id'] as $key) {
        if (!isset($propertyData[$key])) {
            continue;
        }
        $value = trim((string) $propertyData[$key]);
        if ($value !== '') {
            $identifiers[$value] = true;
        }
    }
    foreach (['o:property', 'property'] as $key) {
        if (empty($propertyData[$key]) || !is_array($propertyData[$key])) {
            continue;
        }
        foreach ($propertyData[$key] as $valueKey => $value) {
            if (!in_array($valueKey, ['o:id', 'id', 'o:term', 'term', '@id'], true)) {
                continue;
            }
            $value = trim((string) $value);
            if ($value !== '') {
                $identifiers[$value] = true;
            }
        }
    }
    return $identifiers;
};

$extractGroupLabel = function ($groupData) {
    if (is_scalar($groupData)) {
        $label = trim((string) $groupData);
        return $label !== '' ? $label : null;
    }
    if (!is_array($groupData)) {
        return null;
    }
    foreach (['o:label', 'label', 'o:name', 'name', 'o:title', 'title', 'group', 'o:group'] as $key) {
        if (!isset($groupData[$key])) {
            continue;
        }
        $label = trim((string) $groupData[$key]);
        if ($label !== '') {
            return $label;
        }
    }
    return null;
};

$appendTabPropertyIdentifiers = function (&$tabsByLabel, $label, $propertyData) use ($extractPropertyIdentifiers) {
    if (!isset($tabsByLabel[$label])) {
        $tabsByLabel[$label] = [
            'label' => $label,
            'properties' => [],
        ];
    }
    foreach ($extractPropertyIdentifiers($propertyData) as $identifier => $isEnabled) {
        $tabsByLabel[$label]['properties'][$identifier] = $isEnabled;
    }
};

$getTemplateGroupTabs = function ($resource) use ($extractGroupLabel, $appendTabPropertyIdentifiers, &$templateGroupDebug) {
    if (!isset($resource) || !is_object($resource) || !method_exists($resource, 'resourceTemplate')) {
        return [];
    }
    $template = $resource->resourceTemplate();
    if (!$template || !is_object($template)) {
        return [];
    }
    $templateGroupDebug['template_found'] = true;
    $templateGroupDebug['template_class'] = get_class($template);
    $templateGroupDebug['template_label'] = method_exists($template, 'label') ? $template->label() : null;

    $templateData = method_exists($template, 'jsonSerialize') ? $template->jsonSerialize() : [];
    $tabsByLabel = [];

    foreach (['o:property_groups', 'property_groups', 'o:groups', 'groups'] as $key) {
        if (empty($templateData[$key]) || !is_array($templateData[$key])) {
            continue;
        }
        $templateGroupDebug['template_jsonld_group_keys_present'][] = $key;
        foreach ($templateData[$key] as $groupData) {
            $label = $extractGroupLabel($groupData);
            if ($label === null) {
                continue;
            }
            $templateGroupDebug['template_group_labels'][] = $label;
            foreach (['o:resource_template_property', 'resource_template_properties', 'o:properties', 'properties'] as $propertiesKey) {
                if (empty($groupData[$propertiesKey]) || !is_array($groupData[$propertiesKey])) {
                    continue;
                }
                foreach ($groupData[$propertiesKey] as $propertyData) {
                    $appendTabPropertyIdentifiers($tabsByLabel, $label, $propertyData);
                }
            }
        }
    }

    if ($tabsByLabel) {
        return array_values($tabsByLabel);
    }

    if (!method_exists($template, 'resourceTemplateProperties')) {
        return [];
    }

    foreach ($template->resourceTemplateProperties() as $templateProperty) {
        if (!is_object($templateProperty) || !method_exists($templateProperty, 'jsonSerialize')) {
            continue;
        }
        $templatePropertyData = $templateProperty->jsonSerialize();
        $label = null;
        foreach (['o:property_group', 'property_group', 'o:group', 'group'] as $groupKey) {
            if (empty($templatePropertyData[$groupKey])) {
                continue;
            }
            $label = $extractGroupLabel($templatePropertyData[$groupKey]);
            if ($label !== null) {
                break;
            }
        }
        if ($label === null) {
            continue;
        }
        $templateGroupDebug['template_property_group_labels'][] = $label;
        if (empty($templatePropertyData['o:property'])) {
            continue;
        }
        $appendTabPropertyIdentifiers($tabsByLabel, $label, $templatePropertyData['o:property']);
    }

    return array_values($tabsByLabel);
};

$configuredTabs = [];
if ($useTemplateGroups && isset($resource)) {
    $configuredTabs = $getTemplateGroupTabs($resource);
    if ($configuredTabs) {
        $templateGroupDebug['configured_tabs_source'] = 'template_groups';
    }
}
if (!$configuredTabs) {
    for ($i = 1; $i <= 6; $i++) {
        $label = trim((string) $this->themeSetting(sprintf('resource_page_tab_%d_name', $i), ''));
        if ($label === '') {
            continue;
        }
        $propertiesRaw = $this->themeSetting(sprintf('resource_page_tab_%d_properties', $i));
        $propertyMap = [];
        foreach ($normalizePropertySelectValues($propertiesRaw) as $property) {
            $propertyMap[(string) $property] = true;
        }
        $configuredTabs[] = [
            'label' => $label,
            'properties' => $propertyMap,
        ];
    }
}
$templateGroupDebug['configured_tab_labels'] = array_values(array_map(function ($tab) {
    return $tab['label'];
}, $configuredTabs));
$useTabs = $tabsMode === 'tabs' && count($configuredTabs) >= 2;

$renderProperty = function ($term, $propertyData) use (
    $filterLocale,
    $filterLocaleCallback,
    $translate,
    $labelInfo,
    $escape,
    $collapsibleMap,
    $showLocale,
    $showValueAnnotations,
    $decoration,
    $lang
) {
    $propertyValues = $propertyData['values'];
    if ($filterLocale) {
        $propertyValues = array_filter($propertyValues, $filterLocaleCallback);
    }
    if (!$propertyValues) {
        return;
    }
    $property = $propertyData['property'];
    $propertyLabel = $propertyData['alternate_label'] ?: $translate($property->label());
    if ('term' === $labelInfo) {
        $propertyTerm = $property->term();
    } elseif ('vocab' === $labelInfo) {
        $propertyTerm = $property->vocabulary()->label();
    } else {
        $propertyTerm = null;
    }
    $propertyId = (string) $property->id();
    $isCollapsible = array_key_exists($term, $collapsibleMap) || array_key_exists($propertyId, $collapsibleMap);
    $isOpen = array_key_exists($term, $collapsibleMap)
        ? $collapsibleMap[$term]
        : (array_key_exists($propertyId, $collapsibleMap) ? $collapsibleMap[$propertyId] : false);
    ?>
    <div class="property<?php if ($isCollapsible) echo ' collapsible-property'; ?>">
        <?php if ($isCollapsible): ?>
        <details<?php if ($isOpen) echo ' open'; ?>>
            <summary>
            <?php echo $escape($propertyLabel); ?>
            <?php if ($propertyTerm !== null) : ?>
            <span class="field-term">(<?php echo $escape($propertyTerm); ?>)</span>
            <?php endif; ?>
            </summary>
        <?php else: ?>
        <dt>
        <?php echo $escape($propertyLabel); ?>
        <?php if ($propertyTerm !== null) : ?>
        <span class="field-term">(<?php echo $escape($propertyTerm); ?>)</span>
        <?php endif; ?>
        </dt>
        <?php endif; ?>
        <?php foreach ($propertyValues as $value): ?>
            <?php
            $valueType = $value->type();
            $valueLang = $value->lang();
            $valueAnnotation = $value->valueAnnotation();
            $class = ['value'];
            if ('resource' == $valueType || strpos($valueType, 'resource') !== false) {
                $class[] = 'resource';
                $class[] = $escape($value->valueResource()->resourceName());

                if ('media' == $value->valueResource()->resourceName() && is_array($decoration) && in_array('media', $decoration)) {
                    $class[] = 'decoration decoration--thumbnail';
                }
            } elseif ('uri' == $valueType) {
                $class[] = 'uri';
            }
            ?>
            <dd class="<?php echo implode(' ', $class); ?>" lang="<?php echo $escape($valueLang); ?>">
                <?php if ($showLocale && $valueLang) : ?>
                    <span class="language"><?php echo $valueLang; ?></span>
                <?php endif; ?>
                <span class="value-content"><?php echo $filterLocale ? $value->asHtml($lang) : $value->asHtml(); ?></span>
                <?php if(!$value->isPublic()) : ?>
                    <span class="o-icon-private" aria-role="tooltip" title="<?php echo $this->escapeHtml($translate('Private')); ?>" aria-label="<?php echo $this->escapeHtml($translate('Private')); ?>"></span>
                <?php endif; ?>
                <?php if ($valueAnnotation && $showValueAnnotations) : ?>
                    <div class="annotation-btn">
                        <span class="has-annotation o-icon-annotation" aria-role="tooltip" title="<?php echo $this->escapeHtml($translate('Has annotation')); ?>" aria-label="<?php echo $this->escapeHtml($translate('Has annotation')); ?>"></span>
                        <div class="annotation-tooltip">
                            <div class="annotation-tooltip__wrapper">
                                <h6 class="annotation-tooltip__heading"><?php echo $this->escapeHtml($translate('Value Annotations')); ?></h6>
                                <?php echo $valueAnnotation->displayValues(); ?>
                            </div>
                        </div>
                    </div>
                <?php endif; ?>
                <?php $this->trigger('view.show.value', ['value' => $value]); ?>
            </dd>
        <?php endforeach; ?>
        <?php if ($isCollapsible): ?>
        </details>
        <?php endif; ?>
    </div>
    <?php
};
?>

<div style="background:#fff3cd;border:1px solid #d6b656;color:#4a3b00;padding:12px;margin:0 0 16px;font:12px/1.4 monospace;white-space:pre-wrap;">
<?php echo $escape(json_encode($templateGroupDebug, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE)); ?>
</div>

<?php if (!$useTabs): ?>
<dl>
    <?php foreach ($values as $term => $propertyData): ?>
        <?php $renderProperty($term, $propertyData); ?>
    <?php endforeach; ?>
</dl>
<?php else: ?>
<?php
$tabBuckets = array_fill(0, count($configuredTabs), []);
foreach ($values as $term => $propertyData) {
    $property = $propertyData['property'];
    $propertyId = (string) $property->id();
    $tabIndex = 0;
    foreach ($configuredTabs as $index => $tab) {
        if (isset($tab['properties'][$propertyId]) || isset($tab['properties'][(string) $term])) {
            $tabIndex = $index;
            break;
        }
    }
    $tabBuckets[$tabIndex][$term] = $propertyData;
}
$tabsComponentId = 'resource-values-tabs-' . substr(md5(uniqid((string) mt_rand(), true)), 0, 8);
?>
<div class="resource-values-tabs" data-resource-values-tabs id="<?php echo $escape($tabsComponentId); ?>">
    <div class="tabs is-toggle">
        <ul role="tablist">
            <?php foreach ($configuredTabs as $index => $tab): ?>
            <li class="<?php echo $index === 0 ? 'is-active' : ''; ?>">
                <a
                    href="#<?php echo $escape($tabsComponentId . '-panel-' . $index); ?>"
                    role="tab"
                    aria-selected="<?php echo $index === 0 ? 'true' : 'false'; ?>"
                    data-tab-target="<?php echo $escape($tabsComponentId . '-panel-' . $index); ?>"
                >
                    <?php echo $escape($tab['label']); ?>
                </a>
            </li>
            <?php endforeach; ?>
        </ul>
    </div>
    <?php foreach ($configuredTabs as $index => $tab): ?>
    <div
        id="<?php echo $escape($tabsComponentId . '-panel-' . $index); ?>"
        class="resource-values-tabs__panel"
        style="<?php echo $index === 0 ? '' : 'display: none;'; ?>"
    >
        <dl>
            <?php foreach ($tabBuckets[$index] as $term => $propertyData): ?>
                <?php $renderProperty($term, $propertyData); ?>
            <?php endforeach; ?>
        </dl>
    </div>
    <?php endforeach; ?>
</div>
<style>
.resource-values-tabs .tabs ul {
    border-bottom: 1px solid #dfdfdf;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    list-style: none;
    margin: 0 auto 16px;
    max-width: 100%;
    padding: 0;
}
.resource-values-tabs .tabs li {
    margin-block-start: 0;
    margin-block-end: -1px;
    margin-inline-start: 0;
    margin-inline-end: 12px;
}
.resource-values-tabs .tabs li a {
    border: 0;
    border-bottom: 3px solid transparent;
    color: #676767;
    display: inline-flex;
    justify-content: center;
    min-width: 180px;
    padding: 8px 18px;
    text-decoration: none;
    transition: color .2s ease, border-color .2s ease;
}
.resource-values-tabs .tabs li.is-active a {
    border-bottom-color: var(--secondary, #2B7F8B);
    color: var(--secondary, #2B7F8B);
    font-weight: 600;
}
.resource-values-tabs .tabs li a:hover {
    color: var(--secondary, #2B7F8B);
}
</style>
<script>
if (!window.ScopusResourceValueTabsInitialized) {
    window.ScopusResourceValueTabsInitialized = true;
    document.addEventListener('click', function (event) {
        var tabLink = event.target.closest('[data-tab-target]');
        if (!tabLink) {
            return;
        }
        var wrapper = tabLink.closest('[data-resource-values-tabs]');
        if (!wrapper) {
            return;
        }
        event.preventDefault();
        var targetId = tabLink.getAttribute('data-tab-target');
        wrapper.querySelectorAll('.tabs li').forEach(function (item) {
            item.classList.remove('is-active');
        });
        var currentItem = tabLink.closest('li');
        if (currentItem) {
            currentItem.classList.add('is-active');
        }
        wrapper.querySelectorAll('.resource-values-tabs__panel').forEach(function (panel) {
            panel.style.display = panel.id === targetId ? '' : 'none';
        });
        wrapper.querySelectorAll('[role="tab"]').forEach(function (tab) {
            tab.setAttribute('aria-selected', tab === tabLink ? 'true' : 'false');
        });
    });
}
</script>
<?php endif; ?>
